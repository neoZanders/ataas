package com.chalmers.atas.api.courses

import org.springframework.web.bind.annotation.RestController;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.DeleteMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.RequestBody; 

@RestController
@RequestMapping("/api/courses")
public class CourseController {

    @PostMapping
    public ResponseEntity<Void> createCourse() {
        return ResponseEntity.ok().build();
    }

    @GetMapping
    public ResponseEntity<Void> getCourses() {
        return ResponseEntity.ok().build();
    }

    @PostMapping("/{courseId}/courseConstraints")
    public ResponseEntity<Void> createCourseConstraint(@PathVariable Long courseId) {
        return ResponseEntity.ok().build();
    }

    @DeleteMapping("/{courseId}/courseConstraints/{courseConstraintId}")
    public ResponseEntity<Void> deleteCourseConstraint(
        @PathVariable Long courseId, 
        @PathVariable Long courseConstraintId) {
        return ResponseEntity.ok().build();
    }

    @GetMapping("/{courseId}/courseConstraints")
    public ResponseEntity<Void> getCourseConstraints(@PathVariable Long courseId) {
        return ResponseEntity.ok().build();
    }

    @DeleteMapping("/{courseId}")
    public ResponseEntity<Void> deleteCourse(@PathVariable Long courseId) {
        return ResponseEntity.ok().build();
    }

    @PutMapping("/{courseId}")
    public ResponseEntity<Void> archiveCourse(@PathVariable Long courseId) {
        return ResponseEntity.ok().build();
    }

    @PostMapping("/{courseId}/courseSessions")
    public ResponseEntity<Void> createCourseSession(@PathVariable Long courseId) {
        return ResponseEntity.ok().build();
    }

    @DeleteMapping("/{courseId}/courseSessions/{courseSession}")
    public ResponseEntity<Void> deleteCourseSession(
        @PathVariable Long courseId,
        @PathVariable Long courseSession) {
        return ResponseEntity.ok().build();
    }

    @GetMapping("/{courseId}/courseSessions")
    public ResponseEntity<Void> getCourseSession(@PathVariable Long courseId) {
        return ResponseEntity.ok().build();
    }
}